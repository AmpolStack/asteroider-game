<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score: 0" name="ScoreLabel" style="position: absolute; top: 10px; left: 10px; -unity-font-style: bold; font-size: 16px; color: rgb(255, 255, 255); padding-right: 8px; padding-bottom: 3px; padding-top: 3px; padding-left: 8px; background-color: rgba(0, 0, 0, 0.4);"/>
    <ui:Label text="Fuel: " name="FuelLabel" style="position: absolute; top: 34px; left: 10px; -unity-font-style: bold; font-size: 14px; color: rgb(0, 180, 255); padding-right: 8px; padding-bottom: 3px; padding-top: 3px; padding-left: 8px; background-color: rgba(0, 0, 0, 0.4);"/>
    <ui:Button text="Restart" enable-rich-text="true" name="RestartButton" style="position: absolute; top: 50%; left: 50%; translate: -50% -50%; padding-top: 10px; padding-right: 30px; padding-bottom: 10px; padding-left: 30px; -unity-font-style: bold; font-size: 16px; color: rgb(255, 255, 255); background-color: rgb(232, 28, 55); border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); border-bottom-color: rgb(255, 255, 255); border-left-color: rgb(255, 255, 255);"/>
    <ui:Label text="High Score: 0" name="HighScoreLabel" style="position: absolute; top: 60%; left: 50%; translate: -50% -50%; -unity-font-style: bold; font-size: 14px; color: rgb(255, 255, 255); padding-right: 8px; padding-bottom: 3px; padding-top: 3px; padding-left: 8px; background-color: rgba(0, 0, 0, 0.4);"/>
</ui:UXML>
